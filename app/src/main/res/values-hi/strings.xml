    <string name="app_name">Maisha</string>
    <string name="tagline">अपनी कहानी जिएँ। एक साल में एक कदम।</string>
    <string name="onboarding_skip">छोड़ें</string>
    <string name="onboarding_welcome_body">एक जीवन जिएँ, फैसले करें और देखें कि आपकी कहानी कहाँ जाती है — साल दर साल।</string>
    <string name="onboarding_age_up_title">हर साल जीने के लिए उम्र बढ़ाएँ</string>
    <string name="onboarding_age_up_body">बड़े होने, घटनाओं का सामना करने और अपने आँकड़े बनाने के लिए उम्र बढ़ाएँ पर टैप करें।</string>
    <string name="onboarding_choices_title">आपके फैसले आपका जीवन बनाते हैं</string>
    <string name="onboarding_choices_body">परिवार, दोस्त, करियर और विरासत आपके चुनावों पर प्रतिक्रिया करते हैं — उपलब्धियाँ आपके मील के पत्थर दर्ज करती हैं।</string>
    <string name="onboarding_ready_title">शुरू करने के लिए तैयार?</string>
    <string name="onboarding_ready_body">अपना पात्र बनाएँ और अपना पहला जीवन शुरू करें। तीन स्लॉट अलग-अलग पारिवारिक शाखाओं के लिए।</string>
